{
  "name": "payiq-starter-fixed",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "start": "nuxt start",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init_payiq",
    "prisma:deploy": "prisma migrate deploy",
    "seed": "bun run scripts/seed.ts",
    "seed:admin": "bun run scripts/seed-admin.ts",
    "workers": "bun run server/tasks/workers.ts",
    "db:up": "docker compose up -d postgres redis",
    "db:down": "docker compose down",
    "setup": "bun install && bun run prisma:generate && bun run prisma:migrate && bun run seed",
    "test": "bun test --preload ./tests/setup.ts tests/**/*.test.ts",
    "test:unit": "bun test --preload ./tests/setup.ts tests/**/*.test.ts --timeout 10000",
    "test:e2e": "PAYIQ_RUN_E2E=1 bun test --preload ./tests/setup.ts tests/**/*.e2e.test.ts --timeout 15000",
    "typecheck": "nuxt typecheck",
    "lint": "eslint .",
    "check": "bun run lint && bun run typecheck",
    "reconcile:pending": "bun run scripts/reconcile-pending.ts",
    "reconcile:scheduler": "bun run server/tasks/reconcileScheduler.ts"
  },
  "dependencies": {
    "@nuxt/ui": "^4.6.1",
    "@opentelemetry/api": "^1.9.0",
    "@prisma/client": "6.19.2",
    "@tailwindcss/vite": "^4.2.2",
    "bullmq": "^5.12.7",
    "ioredis": "5.10.1",
    "nanoid": "^5.0.7",
    "nuxt": "^4.0.0",
    "nuxt-i18n-micro": "^3.16.0",
    "prom-client": "^15.1.3",
    "resend": "^6.10.0",
    "tailwindcss": "^4.2.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.0",
    "prisma": "6.19.2",
    "typescript": "^5.8.2"
  },
  "overrides": {
    "ioredis": "5.10.1"
  }
}
