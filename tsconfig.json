{
  "extends": "./.nuxt/tsconfig.json", // ระบุ Path ของไฟล์ code ของคุณ
  "exclude": ["node_modules"],
  "compilerOptions": {
    /* Target & Lib */
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],

    /* Strictness - สำคัญมากสำหรับไฟล์ Auth */
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,

    /* Bun & Nuxt 4 Compatibility */
    "allowImportingTsExtensions": true, // Bun รองรับการ import .ts ตรงๆ
    "noEmit": true,
    "moduleDetection": "force",
    "isolatedModules": true,
    "skipLibCheck": true,

    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "~~/*": ["./*"],
      "@@/*": ["./*"],
      "#server/*": ["./server/*"],
      "@/*": ["./app/*"]
    }
  },
  "include": [
    ".nuxt/**/*.d.ts",
    // "**/*", // <--- สำคัญมาก: ต้องมีบรรทัดนี้เพื่อให้ TS สแกนหาไฟล์ใน folder tests/ และ server/ ด้วย
    "app/**/*",
    "server/**/*",
    "tests/**/*"
  ]
}
